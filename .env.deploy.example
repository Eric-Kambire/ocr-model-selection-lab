# Image locale chargée avec docker load, ou image d'un registre.
OCR_BENCHMARK_IMAGE=erickambire/ocr-model-selection-lab:1.0.1
OCR_BENCHMARK_PORT=7860

# Nombre de jours de conservation des résultats et artefacts de run.
# Une valeur négative désactive la suppression automatique.
RUN_RETENTION_DAYS=30

# Ollama installé sur la machine qui exécute Docker.
OLLAMA_HOST=http://host.docker.internal:11434
