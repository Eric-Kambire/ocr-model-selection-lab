# URL of an Ollama server reachable from the container.
OLLAMA_HOST=http://host.docker.internal:11434

# Keep secrets outside source control. This application does not require Kaggle
# credentials at runtime when the dataset is already present.
KAGGLE_API_TOKEN=

# Rétention des runs locaux (artefacts, sorties OCR et prompts associés).
RUN_RETENTION_DAYS=30
